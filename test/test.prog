0000000010000001

// Testign memory and aritmetic functionss
//  0x0004: ADD R3, R1, R2        R3 = 1 + 2 = 3
0010001010011000

// 0x0006: ST R3, 2(R0)              Mem[2] = R3 (Value 3)
0001000011000010

//0x0008: SUB R4, R1, R2                R4 = 1 - 2 = 0xFFFF
0011001010100000

