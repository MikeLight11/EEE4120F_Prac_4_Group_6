//0111001010101000

//  0x000C: OR R6, R1, R2                    R6 = 1 | 2 = 3
1000001010110000

//  0x000E: SLT R7, R1, R2                   R7 = (1 < 2) = 1
1001001010111000

// Testing branches
// BNE R1, R2, Offset 1.                Branches therefore skips next instruction
1100001010000001

// Next instruction (to be skipped)
set register R4 to EEEE
0000000100001000

// Reserved so no operation
1010 000000000000

// reg 5 and reg 3 == 3 at this point
// BRANCH EQUAL 5 and 3 
1011101011000001

// 
//set register R5 to EEEE
0000000101001000

